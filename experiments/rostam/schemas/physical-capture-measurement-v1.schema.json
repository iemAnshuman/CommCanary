{
  "$id": "commcanary.rostam.physical.capture-measurement.v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifacts": {
      "additionalProperties": {
        "additionalProperties": false,
        "properties": {
          "path": {"minLength": 1, "type": "string"},
          "sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
          "size_bytes": {"minimum": 0, "type": "integer"}
        },
        "required": ["path", "sha256", "size_bytes"],
        "type": "object"
      },
      "minProperties": 1,
      "propertyNames": {"pattern": "^[a-z][a-z0-9_-]*$"},
      "type": "object"
    },
    "attempt_id": {"pattern": "^a-[0-9]{6}$", "type": "string"},
    "count": {"const": 1},
    "global_ranks": {"items": {"minimum": 0, "type": "integer"}, "minItems": 1, "type": "array", "uniqueItems": true},
    "iqr_us": {"const": 0},
    "operation": {"const": "all_reduce"},
    "runtime": {
      "additionalProperties": false,
      "properties": {
        "hostname": {"minLength": 1, "type": "string"},
        "job_id": {"type": ["string", "null"]},
        "python_version": {"minLength": 1, "type": "string"},
        "runtime_nccl_version_code": {"maximum": 99999, "minimum": 1, "type": "integer"},
        "torch_cuda_version": {"type": ["string", "null"]},
        "torch_version": {"minLength": 1, "type": "string"}
      },
      "required": ["hostname", "job_id", "python_version", "runtime_nccl_version_code", "torch_cuda_version", "torch_version"],
      "type": "object"
    },
    "samples_us": {"items": {"minimum": 0, "type": "number"}, "maxItems": 1, "minItems": 1, "type": "array"},
    "value_us": {"minimum": 0, "type": "number"},
    "wall_time_s": {"minimum": 0, "type": "number"},
    "world_size": {"maximum": 1024, "minimum": 1, "type": "integer"}
  },
  "required": ["artifacts", "attempt_id", "count", "global_ranks", "iqr_us", "operation", "runtime", "samples_us", "value_us", "wall_time_s", "world_size"],
  "type": "object"
}
