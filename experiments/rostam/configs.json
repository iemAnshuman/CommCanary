    "shared-replay": {
      "configuration_ids": ["nccl-2.19.3-default", "nccl-2.20.5-default", "nccl-2.20.5-ring-ll", "nccl-2.20.5-ring-ll128", "nccl-2.20.5-ring-simple", "nccl-2.20.5-tree-ll", "nccl-2.20.5-tree-ll128", "nccl-2.20.5-tree-simple"],
      "required_input_ids": ["commcanary-wheel", "environment-lock", "param-patch-contract", "rostam-catalog", "shared-param-trace"],
      "workload_ids": ["shared-overlap"]
