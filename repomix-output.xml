        expected_gap = 0.0
        for index in range(100):
            gap_us = 0.04852 if index else 0.0
            expected_gap += gap_us
            skew = 100.0 if index == 50 else 0.0
            trace["events"].append(
                {
                    "id": f"event-{index}",
                    "phase": "decode",
