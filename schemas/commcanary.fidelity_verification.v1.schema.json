{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://commcanary.dev/schemas/commcanary.fidelity_verification.v1.schema.json",
  "title": "CommCanary fidelity verification v1",
  "description": "Portable output shape for source-fidelity verification. Agreement between the aggregate status, assurance state, and individual checks is not expressed by this schema.",
  "type": "object",
  "required": [
    "format",
    "status",
    "assurance_state",
    "checks"
  ],
  "properties": {
    "format": {
      "const": "commcanary.fidelity_verification.v1"
    },
    "status": {
      "enum": [
        "source_verified",
        "failed"
      ]
    },
    "assurance_state": {
      "enum": [
        "source_corresponding",
        "internally_consistent"
      ]
    },
    "source_events": {
      "$ref": "https://commcanary.dev/schemas/common.schema.json#/$defs/nonNegativeInteger"
    },
    "timing_sample_limit": {
      "$ref": "https://commcanary.dev/schemas/common.schema.json#/$defs/nonNegativeInteger"
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://commcanary.dev/schemas/common.schema.json#/$defs/check"
      }
    }
  },
  "additionalProperties": true
}
